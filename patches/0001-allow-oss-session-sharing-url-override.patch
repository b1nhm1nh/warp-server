index 00000000..785f46e5
--- /dev/null
+++ b/crates/warp_core/src/channel/mod_test.rs
@@ -0,0 +1,28 @@
+use super::Channel;
+
+/// `Oss` must honor server-URL overrides so a self-built OSS binary can be
+/// pointed at a self-hosted server (e.g. a local session-sharing relay) via
+/// `WARP_SESSION_SHARING_SERVER_URL`. `Stable`/`Preview` must not.
+#[test]
+fn server_url_override_allowed_per_channel() {
+    let allowed = [
+        Channel::Dev,
+        Channel::Local,
+        Channel::Integration,
+        Channel::Oss,
+    ];
+    let denied = [Channel::Stable, Channel::Preview];
+
+    for c in allowed {
+        assert!(
+            c.allows_server_url_overrides(),
+            "{c:?} should allow server-url overrides"
+        );
+    }
+    for c in denied {
+        assert!(
+            !c.allows_server_url_overrides(),
+            "{c:?} should deny server-url overrides"
+        );
+    }
+}
